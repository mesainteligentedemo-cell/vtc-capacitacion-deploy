# =============================================================================
# VTC CAPACITACIÓN — Variables de Entorno (EJEMPLO)
# -----------------------------------------------------------------------------
# Copia este archivo como `.env` (o `.env.local` para `vercel dev`) y rellena
# los valores reales. NUNCA comitees el `.env` con claves reales.
#   PowerShell:  Copy-Item .env.example .env
#   Bash:        cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ELEVENLABS — Coach de voz, transcript, audio y memoria
# Usada por: api/transcript.js, api/audio.js, api/report.js, api/history.js
# SERVER-SIDE ONLY — nunca exponer en el frontend.
# -----------------------------------------------------------------------------
ELEVENLABS_AGENT_ID=agent_5701kr0h5gg6eetb69tv6c5hwfj1
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=iDEmt5MnqUotdwCIVplo

# -----------------------------------------------------------------------------
# OPENROUTER — Análisis IA del reporte de sesión (google/gemini-2.5-flash)
# Usada por: api/_analyze.js (vía api/report.js)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# API ENDPOINT — URL base de las funciones serverless / backend VTC
# Dev local:   http://localhost:3000
# Producción:  https://vtc-capacitacion.vercel.app
# -----------------------------------------------------------------------------
VTC_API_ENDPOINT=http://localhost:3000

# -----------------------------------------------------------------------------
# ENTORNO
#   NODE_ENV: development | production
#   DEBUG:    true | false   (logs detallados / verbose)
# -----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=false

# -----------------------------------------------------------------------------
# BACKEND EXPRESS (OPCIONAL) — solo si activas persistencia de usuarios/quiz
# No es necesario para el sitio principal (frontend + funciones serverless).
# -----------------------------------------------------------------------------
PORT=3000
MONGODB_URI=mongodb://localhost:27017/vtc-capacitacion
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:5500
